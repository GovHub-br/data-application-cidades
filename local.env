# <---------- Postgres Data Warehouse ---------->
POSTGRES_USER_DW=postgres_dw
POSTGRES_PASSWORD_DW=postgres_dw
POSTGRES_DB_DW=data_warehouse


# <---------- MinIO ---------->
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=data-lake-ipea

# <---------- Postgres Data Warehouse MCID (Cidades) ---------->
DB_DW_HOST_MCID=
DB_DW_USER_MCID=
DB_DW_PASSWORD_MCID=
DB_DW_PORT_MCID=
DB_DW_DBNAME_MCID=
DB_DW_SCHEMA_MCID=

# <---------- Credenciais do servidor SFTP do MCID (Cidades) ---------->
SFTP_HOST=
SFTP_PORT=
SFTP_USER=
SFTP_PASSWORD=

# Segredo p/ tokenizar CPF/NIS (HMAC-SHA256). NÃO alterar após 1º mascaramento
# (mudar o segredo muda todos os tokens e quebra os joins). Manter em segredo.
MASKING_HMAC_SECRET=
# Diretório p/ arquivos temporários do mascaramento (os Base_PF_FGTS têm ~2GB;
# /tmp é tmpfs pequeno demais). Precisa de ~5GB livres.
MASKING_TMPDIR=
