# =============================================================================
# Database connection configuration for the MCMV classification pipeline.
# Copy this file to .env and fill in the actual credentials.
# =============================================================================

# PostgreSQL host. When using the VPN isolation scripts (scripts/vpn-up.sh),
# use 10.0.0.2 (the veth IP inside the VPN network namespace).
DB_HOST=10.0.0.2

# PostgreSQL port. When using the VPN proxy (socat), this is 5432.
DB_PORT=5432

# Database name.
DB_NAME=dados_historicos

# Database user with read access to source schema and write access to target.
DB_USER=seu_usuario

# Database password.
DB_PASSWORD=sua_senha

# Source schema containing the original 753 tables.
# Read-only access is sufficient.
DB_SCHEMA_SOURCE=dados_historicos

# Target schema where treated tables will be written.
# Requires CREATE and DROP SCHEMA permissions.
DB_SCHEMA_TARGET=dados_historicos_formatados
